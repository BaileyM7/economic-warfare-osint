# ============================================================
# Economic Warfare OSINT System — API Keys & Configuration
# ============================================================
# Copy this file to .env and fill in your keys.
# Only ANTHROPIC_API_KEY is strictly required for the demo.
# All other keys are free-tier — see registration links below.
# ============================================================

# --- REQUIRED ---------------------------------------------------
# Claude API key (https://console.anthropic.com/)
# This is the ONLY paid service. Pay-per-use, ~$5-20 for demo.
ANTHROPIC_API_KEY=

# --- FREE WITH REGISTRATION ------------------------------------

# FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html)
# Used for: macro indicators, VIX, interest rates, commodity proxies
FRED_API_KEY=

# UN Comtrade API key (https://comtradeplus.un.org/TradeFlow)
# Used for: bilateral trade flows, commodity dependencies
COMTRADE_API_KEY=

# ACLED API (https://developer.acleddata.com/)
# Used for: conflict/protest event data
# Register at acleddata.com — free for researchers
ACLED_API_KEY=
ACLED_EMAIL=

# OpenCorporates API (https://api.opencorporates.com/)
# Used for: company search, officer lookup, corporate trees
# Free tier available — optional, works without key (rate limited)
OPENCORPORATES_API_KEY=

# Datalastic — AIS vessel tracking (vessel entity type)
# Free tier: 100 req/day — https://www.datalastic.com/en/api/
# Optional: vessel tracking works in demo/mock mode without this key
DATALASTIC_API_KEY=

# --- NO KEY NEEDED (just works) ---------------------------------
# These sources require no API key:
# - OFAC SDN (U.S. Treasury sanctions list)
# - OpenSanctions.org (unified sanctions database)
# - GLEIF (Legal Entity Identifier registry)
# - ICIJ Offshore Leaks (Panama/Pandora Papers)
# - GDELT 2.0 (global news events)
# - IMF Data APIs
# - World Bank APIs
# - yfinance (Yahoo Finance)
# - SEC EDGAR (requires User-Agent, hardcoded in client)
# - EIA Open Data
# - MarineCadastre AIS

# --- OPTIONAL CONFIG --------------------------------------------
# Claude model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Cache TTL in seconds (default: 3600 = 1 hour)
# CACHE_TTL_SECONDS=3600

# Cache directory (default: data/cache/)
# CACHE_DIR=data/cache

# --- WARGAME TAB (swarm microservice) ---------------------------
# The /wargame tab talks directly to a separately-deployed swarm
# backend (C:\Work\swarm). Set these at the frontend build step
# (e.g. Render dashboard → Environment → Add env var).
# Dev defaults: http://localhost:8000 / ws://localhost:8000.
#
# VITE_SWARM_API_URL=https://swarm-api.example.com
# VITE_SWARM_WS_URL=wss://swarm-api.example.com
#
# Swarm's CORS_ORIGINS must include the Emissary frontend URL.
